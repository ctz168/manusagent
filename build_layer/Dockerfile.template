# Manus Agent Environment - Dockerfile Template
FROM ubuntu:22.04

# 1. Set Environment Variables
ENV DEBIAN_FRONTEND=noninteractive \
    TZ=UTC \
    HOME=/home/ubuntu \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# 2. Install System Dependencies
RUN apt-get update && apt-get install -y \
    curl git supervisor sudo python3 python3-pip \
    xvfb x11vnc chromium-browser \
    net-tools psmisc unzip wget bc openssl \
    && rm -rf /var/lib/apt/lists/*

# 3. Setup User
RUN useradd -m -s /bin/bash ubuntu && \
    echo "ubuntu ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 4. Install Runtimes (Python/Node.js)
USER ubuntu
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash && \
    export NVM_DIR="$HOME/.nvm" && [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" && \
    nvm install 22.13.0 && npm install -g pnpm

# 5. Install Code-Server
USER root
RUN curl -fsSL https://code-server.dev/install.sh | sh

# 6. Setup Directory Structure
RUN mkdir -p /opt/.manus/.packages/scripts \
    /opt/.manus/.sandbox-runtime \
    /var/log/supervisor && \
    chown -R ubuntu:ubuntu /opt/.manus /var/log/supervisor

# 7. Copy Agent Logic (User should provide their own binaries here)
# Note: The 'start_server' binary is proprietary. You must replace it with your own implementation.
# COPY --chown=ubuntu:ubuntu ./your-runtime-binary /opt/.manus/.sandbox-runtime/start_server

# 8. Entrypoint Configuration
COPY ./supervisor_conf/*.conf /etc/supervisor/conf.d/
CMD ["/usr/bin/supervisord", "-n", "-c", "/etc/supervisor/supervisord.conf"]
